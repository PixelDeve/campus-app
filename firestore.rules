rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userDoc().isAdmin == true;
    }

    function isNotBanned() {
      return isSignedIn() && userDoc().isBanned != true;
    }

    // ── users/{userId} ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isOwner(userId) &&
                       request.resource.data.isAdmin == false &&
                       request.resource.data.isBanned == false;

      allow update: if (isOwner(userId) &&
                          request.resource.data.isAdmin == resource.data.isAdmin &&
                          request.resource.data.isBanned == resource.data.isBanned)
                       || isAdmin();

      allow delete: if isAdmin();
    }

    // ── posts/{postId} ──────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && isNotBanned() &&
                       request.resource.data.authorId == request.auth.uid;

      allow update: if isSignedIn() &&
                       (request.auth.uid == resource.data.authorId || isAdmin());

      allow delete: if isSignedIn() &&
                       (request.auth.uid == resource.data.authorId || isAdmin());

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isNotBanned() &&
                         request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() &&
                                 (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    // ── lostFound/{itemId} ──────────────────────────────────────────────
    match /lostFound/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned() &&
                       request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }

    // ── config/inviteCode ───────────────────────────────────────────────
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── friendRequests/{requestId} ───────────────────────────────────────
    match /friendRequests/{requestId} {
      allow read: if isSignedIn() &&
                     (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isSignedIn() && isNotBanned() &&
                       request.resource.data.fromId == request.auth.uid &&
                       request.resource.data.toId != request.auth.uid &&
                       request.resource.data.status == 'pending';
      allow delete: if isSignedIn() &&
                       (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    // ── friendships/{friendshipId} ───────────────────────────────────────
    // Doc id is the two user ids sorted and joined, e.g. "uidA_uidB".
    // Field name is "users": an array of exactly the two participant uids.
    match /friendships/{friendshipId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.auth.uid in request.resource.data.users &&
                       request.resource.data.users.size() == 2;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.users;
    }

    // ── events/{eventId} ──────────────────────────────────────────────────
    // Visible publicly once approved; creator and admins can always see it;
    // only admins can change status (approve/reject).
    match /events/{eventId} {
      allow read: if isSignedIn() &&
                     (resource.data.status == 'approved' ||
                      resource.data.createdBy == request.auth.uid ||
                      isAdmin());
      allow create: if isSignedIn() && isNotBanned() &&
                       request.resource.data.createdBy == request.auth.uid &&
                       request.resource.data.status == 'pending';
      allow update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() &&
                       (request.auth.uid == resource.data.createdBy || isAdmin());
    }

    // ── chats/{chatId} ────────────────────────────────────────────────────
    // Doc id is the two user ids sorted and joined. Field name is
    // "participants": an array of exactly the two chat members. Only the
    // two participants can read/write the chat doc or its messages.
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
                       request.auth.uid in request.resource.data.participants &&
                       request.resource.data.participants.size() == 2;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
                       request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
